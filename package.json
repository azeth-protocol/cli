{
  "name": "@azeth/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for the Azeth trust infrastructure — register, discover, pay, and manage machine participants",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azeth-protocol/cli.git"
  },
  "homepage": "https://azeth.ai",
  "keywords": [
    "azeth",
    "cli",
    "machine-economy",
    "trust-registry",
    "x402",
    "payments"
  ],
  "bin": {
    "azeth": "./bin/azeth.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node bin/azeth.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azeth/common": "^0.1.0",
    "@azeth/sdk": "^0.1.0",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "dotenv": "^16.4.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
